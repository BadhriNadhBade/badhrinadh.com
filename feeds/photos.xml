---
permalink: /photos.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ site.title }}'s photos</title>
    <description>Photos.</description>
    <link>{{ site.url }}/photos</link>
    <atom:link href="{{ site.url }}/photos.xml" rel="self" type="application/rss+xml" />
    {% assign photos = site.data.photos | reverse %}
    {% for photo in photos limit: 20 %}
      <item>
        <title>{{ photo.uploaded | date: "%Y/%m/%d" }}</title>
        <description>{{ photo.meta.caption | xml_escape }}</description>
        <pubDate>{{ photo.uploaded | date_to_rfc822 }}</pubDate>
        <link>{{ site.url }}/photos#P{{ photo.id }}</link>
        <guid isPermaLink="true">{{ site.url }}/photos#P{{ photo.id }}</guid>
        <enclosure url="{{ photo.url }}" type="image/jpeg" length="0" />
      </item>
    {% endfor %}
  </channel>
</rss>
